	(text "The FPGA forces DONE_0 to low before initialization.\nThis will force Y (/HALT) to A, so to low.\nThis will prevent the '030 to do anything until we initialized the FPGA.\nWhen the FPGA is initialized, it releases DONE_0 which is pulled up to high, this forcing Y to Z and letting the\nmotherboard pull-up do its job and HALT_N will go high so the machine starts."
		(exclude_from_sim no)
		(at 215.138 90.424 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "14e4f3a9-2b02-4c8e-a7b7-39695f5d2c82")
	)
